<Window x:Class="demka.Pages.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товары - ООО «Обувь»" Height="650" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="DiscountStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <!-- Без скидки -->
                <DataTrigger Binding="{Binding Discount}" Value="{x:Null}">
                    <Setter Property="Background" Value="#FFFFFF"/>
                </DataTrigger>

                <!-- Скидка > 15% -->
                <DataTrigger Binding="{Binding IsDiscountGreaterThan15}" Value="True">
                    <Setter Property="Background" Value="#2E8B57"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnAdd" Content="Добавить" Width="110" Margin="5" Click="Add_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnEdit" Content="Редактировать" Width="110" Margin="5" Click="Edit_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnDelete" Content="Удалить" Width="110" Margin="5" Click="Delete_Click" Visibility="Collapsed"/>
            <Button Content="Обновить" Width="110" Margin="5" Click="Refresh_Click"/>
            <Button Content="Сбросить фильтры" Width="130" Margin="5" Click="ResetFilters_Click"/>
        </StackPanel>

        <!-- Search and Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="TbSearch" Width="250" Height="30" Margin="5" TextChanged="TbSearch_TextChanged"/>
            <ComboBox x:Name="CbCategory" Width="180" Height="30" Margin="5" 
                      DisplayMemberPath="CategoryName" SelectionChanged="Filter_Changed"/>
            <ComboBox x:Name="CbManufacturer" Width="180" Height="30" Margin="5" 
                      DisplayMemberPath="ManufacturerName" SelectionChanged="Filter_Changed"/>
            <ComboBox x:Name="CbSort" Width="180" Height="30" Margin="5" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="По цене (возр)"/>
                <ComboBoxItem Content="По цене (убыв)"/>
                <ComboBoxItem Content="По названию"/>
            </ComboBox>
        </StackPanel>

        <DataGrid x:Name="ProductsGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" RowStyle="{StaticResource DiscountStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding ProductArticul}" Width="100"/>
                <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="250"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding ProductPrice}" Width="100"/>
                <DataGridTextColumn Header="Скидка %" Binding="{Binding Discount}" Width="80"/>
                <DataGridTextColumn Header="Остаток" Binding="{Binding CountInStock}" Width="80"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding CategoryNavigation.CategoryName}" Width="150"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding ManufacturerNavigation.ManufacturerName}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>