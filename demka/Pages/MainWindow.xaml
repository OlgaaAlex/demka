<Window x:Class="demka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ООО «Обувь» - Главное меню" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        Icon="logo.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TbGreeting" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Button x:Name="BtnProducts" Content="Просмотр товаров" Height="50" Margin="10" Click="Products_Click"/>
            <Button x:Name="BtnOrders" Content="Просмотр заказов" Height="50" Margin="10" Click="Orders_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnAddProduct" Content="Добавить товар" Height="50" Margin="10" Click="AddProduct_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>