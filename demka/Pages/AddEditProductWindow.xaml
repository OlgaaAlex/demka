<!-- demka/Pages/AddEditProductWindow.xaml -->
<Window x:Class="demka.Pages.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="620" Width="520"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Content="Артикул:" Grid.Row="0"/>
        <TextBox x:Name="TbArticul" Grid.Row="0" Margin="120,0,0,5" IsEnabled="False"/>

        <Label Content="Название:" Grid.Row="1"/>
        <TextBox x:Name="TbName" Grid.Row="1" Margin="120,0,0,5"/>

        <Label Content="Единица:" Grid.Row="2"/>
        <TextBox x:Name="TbUnit" Grid.Row="2" Margin="120,0,0,5" Text="пара"/>

        <Label Content="Цена:" Grid.Row="3"/>
        <TextBox x:Name="TbPrice" Grid.Row="3" Margin="120,0,0,5"/>

        <Label Content="Поставщик:" Grid.Row="4"/>
        <ComboBox x:Name="CbSupplier" Grid.Row="4" Margin="120,0,0,5" DisplayMemberPath="SupplierName"/>

        <Label Content="Производитель:" Grid.Row="5"/>
        <ComboBox x:Name="CbManufacturer" Grid.Row="5" Margin="120,0,0,5" DisplayMemberPath="ManufacturerName"/>

        <Label Content="Категория:" Grid.Row="6"/>
        <ComboBox x:Name="CbCategory" Grid.Row="6" Margin="120,0,0,5" DisplayMemberPath="CategoryName"/>

        <Label Content="Скидка %:" Grid.Row="7"/>
        <TextBox x:Name="TbDiscount" Grid.Row="7" Margin="120,0,0,5"/>

        <Label Content="Остаток:" Grid.Row="8"/>
        <TextBox x:Name="TbCount" Grid.Row="8" Margin="120,0,0,5"/>

        <Label Content="Описание:" Grid.Row="9"/>
        <TextBox x:Name="TbDescription" Grid.Row="9" Margin="120,0,0,5" Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>

        <Button Grid.Row="10" Content="Сохранить" HorizontalAlignment="Right" Width="120" Height="35" Margin="0,20,0,0" Click="Save_Click"/>
    </Grid>
</Window>