<Window x:Class="demka.Pages.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказы" Height="600" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,10,10">
            <Button x:Name="BtnAdd" Content="Добавить заказ" Width="140" Margin="5" Click="Add_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnEdit" Content="Редактировать" Width="140" Margin="5" Click="Edit_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnDelete" Content="Удалить" Width="110" Margin="5" Click="Delete_Click" Visibility="Collapsed"/>
            <Button Content="Обновить" Width="110" Margin="5" Click="Refresh_Click"/>
        </StackPanel>

        <DataGrid x:Name="OrdersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  MouseDoubleClick="OrdersGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding OrderId}" Width="60"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130"/>
                <DataGridTextColumn Header="Код" Binding="{Binding OrderCode}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusNavigation.StatusName}" Width="140"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding AddressNavigation.AddressName}" Width="280"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding UserNavigation.LastName}" Width="150"/>
                <DataGridTextColumn Header="Дата выдачи" Binding="{Binding OrderDateIssue, StringFormat={}{0:dd.MM.yyyy}}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>