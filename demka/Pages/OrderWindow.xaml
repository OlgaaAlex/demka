<!-- demka/Pages/OrderWindow.xaml -->
<Window x:Class="demka.Pages.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказы" Height="550" Width="1100">
    <Grid Margin="10">
        <DataGrid x:Name="OrdersGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding OrderId}" Width="60"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                <DataGridTextColumn Header="Код" Binding="{Binding OrderCode}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusNavigation.StatusName}" Width="140"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding AddressNavigation.AddressName}" Width="250"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding UserNavigation.LastName}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>